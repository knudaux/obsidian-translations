{
    "schemaVersion": 1,
    "metadata": {
        "plugin": "settings-search",
        "version": "1.0.0",
        "title": "Settings Search",
        "description": "Settings Search Localization & Tweaks",
        "language": "zh-cn",
        "supportedVersions": "1.3.10",
        "author": "knudxiao"
    },
    "dict": {
        "main.js": {
            "ast": [
                {
                    "type": "CallExpression",
                    "name": "createDiv",
                    "source": "settings-search-container vertical-tab-header-group",
                    "target": "settings-search-container vertical-tab-header-group"
                },
                {
                    "type": "CallExpression",
                    "name": "createDiv",
                    "source": "settings-search-results-container vertical-tab-content",
                    "target": "settings-search-results-container vertical-tab-content"
                },
                {
                    "type": "CallExpression",
                    "name": "createDiv",
                    "source": "vertical-tab-nav-item settings-search-input",
                    "target": "vertical-tab-nav-item settings-search-input"
                },
                {
                    "type": "CallExpression",
                    "name": "setPlaceholder",
                    "source": "Search settings...",
                    "target": "搜索设置..."
                },
                {
                    "type": "CallExpression",
                    "name": "setText",
                    "source": "No results found :(",
                    "target": "未找到结果 :("
                },
                {
                    "type": "NewExpression",
                    "name": "Notice",
                    "source": "There was an issue opening the setting tab.",
                    "target": "打开设置选项卡时出现问题。"
                },
                {
                    "type": "ObjectProperty",
                    "name": "aria-label",
                    "source": "This setting was added by another plugin.",
                    "target": "此设置由另一个插件添加。"
                },
                {
                    "type": "ObjectProperty",
                    "name": "text",
                    "source": "Settings Search Results",
                    "target": "设置搜索结果"
                }
            ],
            "regex": [
                {
                    "source": "setTooltip(`Open ${resource.text} Settings`)",
                    "target": "setTooltip(`打开 ${resource.text} 设置`)"
                },
                {
                    "source": "setPlaceholder(\"Search settings...\")",
                    "target": "setPlaceholder(\"搜索设置...\")"
                },
                {
                    "source": "setText(\"No results found :(\")",
                    "target": "setText(\"未找到结果 :(\")"
                },
                {
                    "source": "Notice(\"There was an issue opening the setting tab.\")",
                    "target": "Notice(\"打开设置选项卡时出现问题。\")"
                },
                {
                    "source": "text: \"Settings Search Results\"",
                    "target": "text: \"设置搜索结果\""
                }
            ]
        }
    }
}